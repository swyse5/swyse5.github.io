/***********************
 * ESPN PGA scoreboard -> Google Sheets
 * - per-hole relative-to-par in C-T
 * - hole PARs (computed) in row 3, C-T
 * - finished round total in column U: "70 (-2)"
 *
 * A1 = event name fragment (e.g. "genesis")
 *
 * Round blocks:
 *   R1 rows 4-43
 *   R2 rows 48-87
 *   R3 rows 92-131
 *   R4 rows 136-175
 ***********************/

const CFG = {
  targetSheetName: "Score Input",
  cellEventName: "A1",

  nameCol: 2,       // B
  holeStartCol: 3,  // C
  holeCount: 18,
  totalCol: 21,     // U

  triggerMinutes: 15,

  roundBlocks: [
    { round: 1, startRow: 4,   endRow: 43 },
    { round: 2, startRow: 48,  endRow: 87 },
    { round: 3, startRow: 92,  endRow: 131 },
    { round: 4, startRow: 136, endRow: 175 }
  ]
};

function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu("Golf Tracker")
    .addItem("Update Now", "updateAllRoundsFromEspn")
    .addSeparator()
    .addItem("Start Auto Update", "startAutoUpdate")
    .addItem("Stop Auto Update", "stopAutoUpdate")
    .addToUi();
}

function startAutoUpdate() {
  stopAutoUpdate();
  ScriptApp.newTrigger("updateAllRoundsFromEspn")
    .timeBased()
    .everyMinutes(CFG.triggerMinutes)
    .create();
}

function stopAutoUpdate() {
  ScriptApp.getProjectTriggers().forEach(t => {
    if (t.getHandlerFunction() === "updateAllRoundsFromEspn") {
      ScriptApp.deleteTrigger(t);
    }
  });
}

function updateAllRoundsFromEspn() {
  const ss = SpreadsheetApp.getActive();
  const sheet = CFG.targetSheetName ? ss.getSheetByName(CFG.targetSheetName) : ss.getActiveSheet();
  if (!sheet) throw new Error(`Sheet not found: "${CFG.targetSheetName}"`);

  const wantedEventName = String(sheet.getRange(CFG.cellEventName).getValue()).trim();

  const scoreboard = fetchJson_("https://site.api.espn.com/apis/site/v2/sports/golf/pga/scoreboard");
  const event = pickEvent_(scoreboard, wantedEventName);
  if (!event) throw new Error("No events found in ESPN scoreboard response.");

  const competitors = event?.competitions?.[0]?.competitors || [];

  // ✅ NEW: write par row (row 3, C-T) by computing par = strokes - (toPar)
  const pars = computeParsFromCompetitors_(competitors);
  if (pars && pars.length === CFG.holeCount) {
    sheet.getRange(3, CFG.holeStartCol, 1, CFG.holeCount).setValues([pars]);
  }

  // Update each round block
  CFG.roundBlocks.forEach(block => {
    const { holesByName, totalByName } = buildRoundMapsFromEspn_(competitors, block.round);

    const rowCount = block.endRow - block.startRow + 1;
    if (rowCount <= 0) return;

    const names = sheet.getRange(block.startRow, CFG.nameCol, rowCount, 1)
      .getValues()
      .map(r => String(r[0] || "").trim());

    const holesOut = [];
    const totalsOut = [];

    names.forEach(n => {
      if (!n) {
        holesOut.push(Array(CFG.holeCount).fill(""));
        totalsOut.push([""]);
        return;
      }

      const key = normalizeName_(n);
      holesOut.push(holesByName.get(key) || Array(CFG.holeCount).fill(""));
      totalsOut.push([ totalByName.get(key) || "" ]);
    });

    // Write hole-by-hole rel-to-par
    sheet.getRange(block.startRow, CFG.holeStartCol, holesOut.length, CFG.holeCount).setValues(holesOut);

    // ✅ NEW: write total in U
    sheet.getRange(block.startRow, CFG.totalCol, totalsOut.length, 1).setValues(totalsOut);
  });

  sheet.getRange("B1").setValue(`Last updated: ${new Date().toLocaleString()}`);
}

function fetchJson_(url) {
  const res = UrlFetchApp.fetch(url, {
    method: "get",
    muteHttpExceptions: true,
    headers: { "Accept": "application/json" }
  });
  const code = res.getResponseCode();
  const text = res.getContentText();
  if (code !== 200) throw new Error(`HTTP ${code}\nURL: ${url}\nBody: ${text.slice(0, 500)}`);
  return JSON.parse(text);
}

function pickEvent_(scoreboard, wantedName) {
  const events = scoreboard?.events || [];
  if (!events.length) return null;

  if (!wantedName) return events[0];

  const wantedNorm = normalizeEventName_(wantedName);
  const match = events.find(e => normalizeEventName_(e.name || e.shortName || "").includes(wantedNorm));
  return match || events[0];
}

/**
 * ✅ NEW:
 * Compute hole pars from any available competitor/hole:
 * hole par = hole strokes (value) - hole score-to-par (scoreType.displayValue)
 *
 * Returns array[18] of pars (numbers/blanks).
 */
function computeParsFromCompetitors_(competitors) {
  const pars = Array(CFG.holeCount).fill("");

  for (const c of competitors) {
    const rounds = Array.isArray(c.linescores) ? c.linescores : [];
    for (const r of rounds) {
      const holes = r?.linescores || [];
      for (const h of holes) {
        const holeNo = Number(h.period);
        if (!(holeNo >= 1 && holeNo <= CFG.holeCount)) continue;
        if (pars[holeNo - 1] !== "") continue;

        const strokes = Number(h.value);
        const toPar = normalizeRelToPar_(h?.scoreType?.displayValue); // -1, 0, +2...
        if (!Number.isFinite(strokes) || strokes <= 0) continue;
        if (!Number.isFinite(toPar)) continue;

        const par = Math.round(strokes - toPar);
        if (par >= 3 && par <= 5) { // sanity check
          pars[holeNo - 1] = par;
        }
      }
      if (pars.every(p => p !== "")) return pars;
    }
  }

  // If we didn't find all 18, return what we have (or null if nothing)
  return pars.some(p => p !== "") ? pars : null;
}

/**
 * Build maps for a single round:
 * - holesByName: normalizedName -> array[18] rel-to-par (numbers / blanks)
 * - totalByName: normalizedName -> "70 (-2)" ONLY if round finished
 *
 * ESPN round object has:
 *   roundObj.value = total strokes
 *   roundObj.displayValue = to-par ("-1","E","+2")
 * and each hole has:
 *   h.value = strokes
 *   h.scoreType.displayValue = to-par for that hole
 */
function buildRoundMapsFromEspn_(competitors, roundNumber) {
  const holesByName = new Map();
  const totalByName = new Map();
  const roundIndex = roundNumber - 1;

  competitors.forEach(c => {
    const name = c?.athlete?.displayName || c?.athlete?.fullName || "";
    if (!name) return;
    const key = normalizeName_(name);

    const roundObj = Array.isArray(c.linescores) ? c.linescores[roundIndex] : null;
    const holeObjs = roundObj?.linescores || [];

    // Holes rel-to-par
    const holes = Array(CFG.holeCount).fill("");
    holeObjs.forEach(h => {
      const holeNo = Number(h.period);
      const rel = h?.scoreType?.displayValue; // "-1","E","+2"
      if (holeNo >= 1 && holeNo <= CFG.holeCount) {
        holes[holeNo - 1] = normalizeRelToPar_(rel);
      }
    });

    if (holes.some(v => v !== "")) holesByName.set(key, holes);

    // Finished round total in column U as "70 (-2)"
    // Consider finished if we have 18 holes with strokes > 0
    const finished =
      Array.isArray(holeObjs) &&
      holeObjs.length >= 18 &&
      holeObjs.filter(h => Number(h.period) >= 1 && Number(h.period) <= 18)
             .every(h => Number(h.value) > 0);

    if (finished && roundObj) {
      const totalStrokes = Number(roundObj.value);
      const toParDisp = String(roundObj.displayValue ?? "").trim(); // "-2", "E", "+1"
      if (Number.isFinite(totalStrokes) && toParDisp) {
        totalByName.set(key, `${Math.round(totalStrokes)} (${toParDisp})`);
      }
    }
  });

  return { holesByName, totalByName };
}

function normalizeRelToPar_(v) {
  if (v == null) return "";
  const s = String(v).trim();
  if (!s) return "";
  if (s.toUpperCase() === "E") return 0;
  const cleaned = s.replace(/^\+/, "");
  const n = Number(cleaned);
  return Number.isFinite(n) ? n : "";
}

function normalizeName_(s) {
  return String(s || "")
    .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .replace(/[^a-z\s]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function normalizeEventName_(s) {
  return String(s || "")
    .toLowerCase()
    .replace(/[^a-z0-9\s]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}